# ============================================================
# ai powered voice based 24.7 booking system — Environment Variables
# Copy to .env and fill in values (run scripts/generate_keys.sh)
# NEVER commit .env to git — add it to .gitignore
# ============================================================

# --- ENCRYPTION (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY_44_CHARS

# --- JWT SECRETS (generate with: openssl rand -hex 32) ---
ARI_JWT_SECRET=REPLACE_WITH_64_CHAR_HEX
WS_JWT_SECRET=REPLACE_WITH_64_CHAR_HEX

# --- RTP SIGNING (generate with: openssl rand -hex 32) ---
RTP_SECRET=REPLACE_WITH_64_CHAR_HEX

# --- REDIS ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD
REDIS_DEDUP_TTL_SECONDS=300

# --- ASTERISK ARI ---
ASTERISK_HOST=127.0.0.1
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=asterisk
ASTERISK_ARI_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD

# --- MODEL PATHS ---
SMOLLM_MODEL_PATH=models/smollm-335m-finetuned.Q4_K_M.gguf
WHISPER_MODEL_PATH=models/tiny.en.Q4_K_M.gguf
WHISPER_LANGUAGE=en

# --- DATABASE ---
SQLITE_DB_PATH=database/bookings.sqlite

# --- SERVER PORTS ---
PYTHON_API_PORT=8001
NODE_SERVER_PORT=8000
WEBSOCKET_PORT=8080
REACT_PORT=3000

# --- SECURITY POLICY ---
RATE_LIMIT_BOOKINGS_PER_HOUR=5
ALLOWED_WEBSOCKET_ORIGINS=http://localhost:3000
ALLOWED_ARI_IPS=127.0.0.1

# --- CPU TUNING ---
LLM_N_THREADS=4
LLM_N_BATCH=8
LLM_N_CTX=512
LLM_MAX_TOKENS=64
LLM_TEMPERATURE=0.1

# --- LOGGING ---
LOG_LEVEL=INFO
AUDIT_LOG_PATH=logs/audit.log
